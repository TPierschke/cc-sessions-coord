{
  "name": "ccsessionscoord.channelbridge",
  "version": "0.3.11",
  "private": true,
  "description": "stdio MCP bridge: Postgres LISTEN/NOTIFY -> Claude Code notifications/claude/channel + coord tools",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "verify": "node ../../tests/smoke/bridge-contract.mjs",
    "verify:http": "node ../../tests/smoke/bridge-http-inject.mjs",
    "verify:render": "node ../../tests/smoke/render-injection.mjs",
